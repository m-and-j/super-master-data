{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-rename",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-watch",
    "fs:read-dirs",
    { "identifier": "fs:scope", "allow": ["**/*"] },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "updater:default",
    "process:default"
  ]
}
